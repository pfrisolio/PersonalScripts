$username = "MonkeyDLuffy"
$presetPassword = "7zNEh4z9zSXx2mDpImwjvIlNzY"   # <-- set your preset password here

# Create user if missing
if (-not (Get-LocalUser -Name $username -ErrorAction SilentlyContinue)) {
    $sec = ConvertTo-SecureString $presetPassword -AsPlainText -Force
    New-LocalUser -Name $username -Password $sec -FullName $username `
       -PasswordNeverExpires -AccountNeverExpires | Out-Null
}

# Get local Administrators group by SID (works on any language)
$adminGroup = Get-LocalGroup | Where-Object { $_.SID -eq "S-1-5-32-544" }

# Ensure member is added (use computer-qualified name)
$member = "$env:COMPUTERNAME\$username"

if (-not (Get-LocalGroupMember -Group $adminGroup.Name -ErrorAction SilentlyContinue | Where-Object { $_.Name -ieq $member })) {
    Add-LocalGroupMember -Group $adminGroup.Name -Member $member -ErrorAction Stop
}
